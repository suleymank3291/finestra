const N = KATEGORILER.length;

function UrunSatiri({ isim, fiyat }: Urun) {
  return (
    <div className="flex items-end py-[14px] border-b" style={{ borderColor: "rgba(44,62,45,0.08)" }}>
      <span
        className="shrink-0 font-montserrat font-light text-sm md:text-base leading-tight pb-[2px]"
        style={{ color: "var(--text-main)" }}
      >
        {isim}
      </span>
      <span
        className="flex-1 mx-3 md:mx-5"
        style={{
          display: "inline-block",
          backgroundImage: "radial-gradient(circle, rgba(44,62,45,0.22) 1.5px, transparent 1.5px)",
          backgroundSize: "7px 7px",
          backgroundRepeat: "repeat-x",
          backgroundPosition: "left bottom 4px",
          height: "1em",
          minWidth: 0,
        }}
      />
      <span
        className="shrink-0 font-montserrat font-medium text-sm md:text-base tabular-nums pb-[2px]"
        style={{ color: "#C4A47C" }}
      >
        {fiyat}
      </span>
    </div>
  );
}

function AltGrupBlok({ grup }: { grup: AltGrup }) {
  return (
    <div className="mb-14 md:mb-20">
      <div className="flex items-center gap-4 mb-7">
        <span className="inline-block w-5 h-px shrink-0" style={{ backgroundColor: "#C4A47C" }} />
        <h3
          className="font-playfair text-lg md:text-2xl italic leading-none"
          style={{ color: "var(--primary-accent)" }}
        >
          {grup.baslik}
        </h3>
        <div className="flex-1 h-px" style={{ backgroundColor: "rgba(196,164,124,0.2)" }} />
      </div>
      <div
        className={`flex flex-col md:flex-row items-stretch gap-7 md:gap-12 ${
          !grup.gorselSol ? "md:flex-row-reverse" : ""
        }`}
      >
        <div className="shrink-0 w-full md:w-[260px] rounded-2xl overflow-hidden self-stretch min-h-[220px] relative">
          <Image src={grup.gorsel} alt={grup.baslik} fill className="object-cover" />
        </div>
        <div className="flex-1 min-w-0 flex flex-col justify-center">
          {grup.urunler.map((u) => (
            <UrunSatiri key={u.isim} {...u} />
          ))}
        </div>
      </div>
    </div>
  );
}

function KategoriPanel({ kat }: { kat: Kategori }) {
  return (
    <div className="max-w-5xl mx-auto px-6 md:px-10 py-12 md:py-18">
      <div className="mb-10 md:mb-14">
        <p
          className="font-montserrat text-[10px] font-semibold tracking-[0.3em] uppercase mb-3"
          style={{ color: "rgba(196,164,124,0.65)" }}
        >
          Finestra Menüsü
        </p>
        <h2
          className="font-playfair text-5xl md:text-7xl italic leading-none"
          style={{ color: "var(--primary-accent)" }}
        >
          {kat.isim}
        </h2>
        <div className="mt-4 h-[2px] w-16 rounded-full" style={{ backgroundColor: "#C4A47C" }} />
      </div>
      {kat.altGruplar.map((grup) => (
        <AltGrupBlok key={grup.baslik} grup={grup} />
      ))}
    </div>
  );
}

export default function MenuSayfasi() {
  const searchParams = useSearchParams();
  const baslangicIdx = Math.max(0, KATEGORILER.findIndex(k => k.slug === searchParams.get("k")));

  const [aktifIdx, setAktifIdx]  = useState(baslangicIdx);
  const aktifIdxRef  = useRef(baslangicIdx);
  const stripRef     = useRef<HTMLDivElement>(null);
  const containerRef = useRef<HTMLDivElement>(null);
  const panelRefs    = useRef<(HTMLDivElement | null)[]>([]);
  const tweenRef     = useRef<gsap.core.Tween | null>(null);
  const progressObj  = useRef({ v: baslangicIdx });

  useLayoutEffect(() => {
    const panel = panelRefs.current[baslangicIdx];
    if (containerRef.current && panel)
      containerRef.current.style.height = `${panel.scrollHeight}px`;
    if (stripRef.current && baslangicIdx > 0)
      gsap.set(stripRef.current, { x: `-${baslangicIdx * (100 / N)}%` });
  }, [baslangicIdx]);

  useEffect(() => {
    const panel = panelRefs.current[aktifIdx];
    if (containerRef.current && panel)
      containerRef.current.style.height = `${panel.scrollHeight}px`;
  }, [aktifIdx]);

  const goToKat = useCallback((idx: number) => {
    if (idx === aktifIdxRef.current) return;
    tweenRef.current?.kill();
    aktifIdxRef.current = idx;
    setAktifIdx(idx);
    const dist = Math.abs(idx - progressObj.current.v);
    tweenRef.current = gsap.to(progressObj.current, {
      v: idx,
      duration: 0.55 + dist * 0.1,
      ease: "power3.inOut",
      onUpdate() {
        if (stripRef.current)
          gsap.set(stripRef.current, { x: `-${progressObj.current.v * (100 / N)}%` });
      },
      onComplete() {
        const panel = panelRefs.current[idx];
        if (containerRef.current && panel)
          containerRef.current.style.height = `${panel.scrollHeight}px`;
      },
    });
  }, []);

  return (
    <>
      <Navbar />
      <main data-navbar-color="#2C3E2D" className="pt-28 md:pt-36" style={{ backgroundColor: "var(--bg-color)" }}>

        {/* Başlık */}
        <div className="max-w-5xl mx-auto px-6 md:px-10 pt-8 pb-2 text-center">
          <h1 className="font-playfair text-6xl md:text-8xl italic" style={{ color: "var(--primary-accent)" }}>
            Menümüz
          </h1>
          <p className="font-montserrat text-sm mt-3" style={{ color: "var(--text-muted)" }}>
            El yapımı lezzetler, nitelikli içecekler.
          </p>
        </div>

        {/* Sticky kategori sekmesi */}
        <div
          className="sticky top-0 z-40 mt-8"
          style={{ backgroundColor: "var(--bg-color)", borderBottom: "1px solid rgba(44,62,45,0.08)" }}
        >
          <div className="max-w-7xl mx-auto px-6 md:px-16">
            <div className="flex items-center py-4 justify-between w-full gap-2">
              {KATEGORILER.map((k, i) => {
                const aktif = i === aktifIdx;
                return (
                  <button
                    key={k.slug}
                    onClick={() => goToKat(i)}
                    className="relative shrink-0 pb-2 font-montserrat text-[10px] md:text-xs font-medium tracking-widest uppercase transition-colors duration-300 text-center"
                    style={{ color: aktif ? "#2C3E2D" : "rgba(44,62,45,0.35)" }}
                  >
                    {k.isim}
                    <span
                      className="absolute bottom-0 left-0 w-full h-[1.5px] rounded-full origin-left"
                      style={{
                        backgroundColor: "#C4A47C",
                        transform: aktif ? "scaleX(1)" : "scaleX(0)",
                        transition: "transform 0.35s cubic-bezier(0.22,1,0.36,1)",
                      }}
                    />
                  </button>
                );
              })}
            </div>
          </div>
        </div>

        {/* GSAP şerit */}
        <div ref={containerRef} style={{ overflow: "hidden", position: "relative" }}>
          <div
            ref={stripRef}
            style={{ display: "flex", width: `${N * 100}%`, alignItems: "flex-start" }}
          >
            {KATEGORILER.map((kat, i) => (
              <div
                key={kat.slug}
                ref={(el) => { panelRefs.current[i] = el; }}
                style={{ width: `${100 / N}%`, flexShrink: 0 }}
              >
                <KategoriPanel kat={kat} />
              </div>
            ))}
          </div>
        </div>

        {/* CTA */}
        <div data-navbar-color="#ffffff" style={{ backgroundColor: "#2C3E2D" }} className="py-20 md:py-28 px-6">
          <div className="max-w-2xl mx-auto text-center">
            <p
              className="font-montserrat text-[10px] font-semibold tracking-[0.3em] uppercase mb-5"
              style={{ color: "rgba(196,164,124,0.5)" }}
            >
              Finestra Cafe
            </p>
            <h2 className="font-playfair text-4xl md:text-6xl italic text-white leading-tight mb-4">
              Siparişinizi
              <em className="block not-italic" style={{ color: "rgba(255,255,255,0.22)" }}>verelim mi?</em>
            </h2>
            <p
              className="font-montserrat text-sm md:text-base leading-relaxed mb-10 max-w-md mx-auto"
              style={{ color: "rgba(255,255,255,0.45)" }}
            >
              Instagram üzerinden bize ulaşın ya da şubelerimizden birini ziyaret edin.
            </p>
            <a
              href="https://www.instagram.com/finestra_cafe"
              target="_blank"
              rel="noopener noreferrer"
              className="inline-flex items-center gap-3 px-10 py-4 font-montserrat font-semibold text-xs tracking-widest uppercase rounded-full transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl"
              style={{ backgroundColor: "#C4A47C", color: "#fff" }}
            >
              @finestra_cafe
            </a>
          </div>
        </div>

      </main>
      <Footer />
    </>
  );
}
